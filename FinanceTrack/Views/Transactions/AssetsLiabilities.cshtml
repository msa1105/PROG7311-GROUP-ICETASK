@{
    ViewData["Title"] = "Assets vs Liabilities";
}

<div class="page-header">
    <div class="page-title">
        <h1>Assets & Liabilities</h1>
        <p>Balance sheet and financial position</p>
    </div>
</div>

<div class="grid-cards">
    <div class="card">
        <div class="card-title">Total Assets</div>
        <div class="card-value" style="color: var(--accent);">R @ViewBag.TotalAssets</div>
    </div>
    <div class="card">
        <div class="card-title">Total Liabilities</div>
        <div class="card-value" style="color: var(--warning);">R @ViewBag.TotalLiabilities</div>
    </div>
    <div class="card">
        <div class="card-title">Current Ratio</div>
        <div class="card-value" style="color: var(--success);">
            @(ViewBag.TotalLiabilities > 0 ? (ViewBag.TotalAssets / ViewBag.TotalLiabilities).ToString("0.00") : "N/A")
        </div>
    </div>
</div>

<div class="chart-card">
    <div style="position: relative; height: 350px; width: 100%;">
        <canvas id="balanceChart"></canvas>
    </div>
</div>

@section Scripts {
    <script>
        const ctx = document.getElementById('balanceChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: ['Total Profile'],
                datasets: [
                    {
                        label: 'Assets',
                        data: [@ViewBag.TotalAssets],
                        backgroundColor: '#3b82f6',
                        borderRadius: 4
                    },
                    {
                        label: 'Liabilities',
                        data: [@ViewBag.TotalLiabilities],
                        backgroundColor: '#f59e0b',
                        borderRadius: 4
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: { beginAtZero: true, grid: { color: 'rgba(255,255,255,0.05)' }}
                }
            }
        });
    </script>
}
