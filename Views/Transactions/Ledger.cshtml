@model IEnumerable<FinanceTrack.Models.Transaction>

@{
    ViewData["Title"] = "Ledger";
}

<div class="page-header">
    <div class="page-title">
        <h1>General Ledger</h1>
        <p>Complete transaction history</p>
    </div>
    <a href="#" class="btn">+ Add Transaction</a>
</div>

<div class="ledger-controls">
    <input type="text" class="search-input" placeholder="Search by ID, entity name, or category..." />
    <select class="filter-select">
        <option>All Types</option>
        <option>Income</option>
        <option>Expense</option>
        <option>Liability</option>
        <option>Asset</option>
    </select>
    <select class="filter-select">
        <option>All Status</option>
        <option>Pending</option>
        <option>Paid</option>
    </select>
    <input type="date" class="filter-select" />
    <span style="color: var(--text-secondary); margin: 0 8px;">to</span>
    <input type="date" class="filter-select" />
</div>

<div style="font-size: 13px; color: var(--text-secondary); margin-bottom: 12px;">
    Showing @Model.Count() transactions
</div>

<div class="table-container">
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Date</th>
                <th>Type</th>
                <th>Entity</th>
                <th>Category</th>
                <th>Amount</th>
                <th>Status</th>
                <th>Due Date</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var tx in Model)
            {
                <tr>
                    <td style="color: var(--text-tertiary)">#@tx.Id</td>
                    <td>@tx.Date.ToShortDateString()</td>
                    <td><span class="badge type-@(tx.Type.ToLower())">@tx.Type</span></td>
                    <td>@tx.EntityName</td>
                    <td>@tx.Category</td>
                    <td class="@(tx.Type == "Income" || tx.Type == "Asset" ? "positive" : "negative")" style="font-weight: 500;">
                        @(tx.Type == "Income" || tx.Type == "Asset" ? "+" : "-")R @tx.Amount
                    </td>
                    <td>
                        <span class="badge @(tx.Status.ToLower())">@tx.Status</span>
                    </td>
                    <td>@(tx.DueDate?.ToShortDateString() ?? "-")</td>
                </tr>
            }
        </tbody>
    </table>
</div>
