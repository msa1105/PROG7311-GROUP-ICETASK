@model FinanceTrack.Models.Transaction
@{
    ViewData["Title"] = "Delete Transaction";
}

<h2>Delete Transaction #@Model.Id</h2>

<p>Are you sure you want to delete this transaction?</p>

<table class="table">
    <tr><th>Date</th><td>@Model.Date.ToShortDateString()</td></tr>
    <tr><th>Type</th><td>@Model.Type</td></tr>
    <tr><th>Entity</th><td>@Model.EntityName</td></tr>
    <tr><th>Category</th><td>@Model.Category</td></tr>
    <tr><th>Amount</th><td>R @Model.Amount.ToString("N2")</td></tr>
    <tr><th>Status</th><td>@Model.Status</td></tr>
</table>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Yes, Delete</button>
    <a asp-action="Ledger" class="btn">Cancel</a>
</form>