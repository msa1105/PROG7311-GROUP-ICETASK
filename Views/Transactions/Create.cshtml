@model FinanceTrack.Models.Transaction
@{
    ViewData["Title"] = "Add Transaction";
}

<h2>Add Transaction</h2>

<form asp-action="Create" method="post">
    <div>
        <label>Date</label>
        <input asp-for="Date" type="date" required />
    </div>
    <div>
        <label>Type</label>
        <select asp-for="Type">
            <option>Income</option>
            <option>Expense</option>
            <option>Asset</option>
            <option>Liability</option>
        </select>
    </div>
    <div>
        <label>Entity</label>
        <input asp-for="EntityName" />
    </div>
    <div>
        <label>Category</label>
        <input asp-for="Category" />
    </div>
    <div>
        <label>Amount</label>
        <input asp-for="Amount" type="number" step="0.01" />
    </div>
    <div>
        <label>Status</label>
        <select asp-for="Status">
            <option>Paid</option>
            <option>Pending</option>
        </select>
    </div>
    <div>
        <label>Due Date</label>
        <input asp-for="DueDate" type="date" />
    </div>
    <button type="submit" class="btn">Save</button>
    <a asp-action="Ledger" class="btn">Cancel</a>
</form>