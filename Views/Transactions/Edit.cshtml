@model FinanceTrack.Models.Transaction
@{
    ViewData["Title"] = "Edit Transaction";
}

<div class="page-header">
    <div class="page-title">
        <h1>Edit Transaction #@Model.Id</h1>
        <p>Update the details of this transaction</p>
    </div>
</div>

<div class="table-container" style="max-width: 600px;">
    <form asp-action="Edit" method="post" style="display:flex; flex-direction:column; gap:16px;">
        <div asp-validation-summary="ModelOnly" style="color:var(--danger);"></div>
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />

        <div class="form-group">
            <label>Date</label>
            <input asp-for="Date" type="date" class="form-control" required />
            <span asp-validation-for="Date" style="color:var(--danger);font-size:12px;"></span>
        </div>
        <div class="form-group">
            <label>Type</label>
            <select asp-for="Type" class="form-control">
                <option>Income</option>
                <option>Expense</option>
                <option>Asset</option>
                <option>Liability</option>
                <option>Receivable</option>
            </select>
        </div>
        <div class="form-group">
            <label>Entity Name</label>
            <input asp-for="EntityName" class="form-control" placeholder="e.g. Acme Corp" />
        </div>
        <div class="form-group">
            <label>Category</label>
            <input asp-for="Category" class="form-control" required />
            <span asp-validation-for="Category" style="color:var(--danger);font-size:12px;"></span>
        </div>
        <div class="form-group">
            <label>Amount (R)</label>
            <input asp-for="Amount" type="number" step="0.01" min="0.01" class="form-control" required />
            <span asp-validation-for="Amount" style="color:var(--danger);font-size:12px;"></span>
        </div>
        <div class="form-group">
            <label>Status</label>
            <select asp-for="Status" class="form-control">
                <option>Pending</option>
                <option>Paid</option>
            </select>
        </div>
        <div class="form-group">
            <label>Due Date</label>
            <input asp-for="DueDate" type="date" class="form-control" />
        </div>
        <div class="form-group">
            <label>Description</label>
            <input asp-for="Description" class="form-control" placeholder="Optional notes" />
        </div>

        <div style="display:flex; gap:10px; margin-top:8px;">
            <button type="submit" class="btn">Save Changes</button>
            <a asp-action="Ledger" class="btn" style="background:var(--bg-secondary);">Cancel</a>
        </div>
    </form>
</div>

<style>
    .form-group { display:flex; flex-direction:column; gap:6px; }
    .form-group label { font-size:13px; color:var(--text-secondary); font-weight:500; }
    .form-control { padding:10px 12px; border:1px solid var(--border); border-radius:6px; font-size:14px; font-family:inherit; background:var(--bg-secondary); color:var(--text-primary); }
    .form-control:focus { outline:none; border-color:var(--accent); }
</style>
