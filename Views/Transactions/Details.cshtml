@model FinanceTrack.Models.Transaction
@{
    ViewData["Title"] = "Transaction Details";
}

<div class="page-header">
    <div class="page-title">
        <h1>Transaction #@Model.Id</h1>
        <p>Full details for this transaction</p>
    </div>
</div>

<div class="table-container" style="max-width:600px;">
    <table>
        <tr><th style="width:140px; color:var(--text-secondary);">Date</th><td>@Model.Date.ToShortDateString()</td></tr>
        <tr><th style="color:var(--text-secondary);">Type</th><td><span class="badge type-@(Model.Type.ToLower())">@Model.Type</span></td></tr>
        <tr><th style="color:var(--text-secondary);">Entity</th><td>@Model.EntityName</td></tr>
        <tr><th style="color:var(--text-secondary);">Category</th><td>@Model.Category</td></tr>
        <tr><th style="color:var(--text-secondary);">Amount</th><td style="font-weight:600;">R @Model.Amount.ToString("N2")</td></tr>
        <tr><th style="color:var(--text-secondary);">Status</th><td><span class="badge @(Model.Status.ToLower())">@Model.Status</span></td></tr>
        <tr><th style="color:var(--text-secondary);">Due Date</th><td>@(Model.DueDate?.ToShortDateString() ?? "-")</td></tr>
        <tr><th style="color:var(--text-secondary);">Description</th><td>@(Model.Description ?? "-")</td></tr>
        <tr><th style="color:var(--text-secondary);">Created</th><td>@Model.CreatedAt.ToLocalTime().ToString("g")</td></tr>
        <tr><th style="color:var(--text-secondary);">Updated</th><td>@Model.UpdatedAt.ToLocalTime().ToString("g")</td></tr>
    </table>
    <div style="display:flex; gap:10px; margin-top:20px;">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="btn" style="background:var(--warning);color:#000;">Edit</a>
        <a asp-action="Ledger" class="btn" style="background:var(--bg-secondary);">Back to Ledger</a>
    </div>
</div>
