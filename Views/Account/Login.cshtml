@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Login - FinanceTrack</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <style>
        body { background-color: var(--bg-primary); display: flex; justify-content: center; align-items: center; height: 100vh; }
        .auth-container { background: var(--bg-card); width: 400px; padding: 40px; border-radius: var(--radius); border: 1px solid var(--border); box-shadow: 0 4px 6px rgba(0,0,0,0.05); }
        .auth-container .brand { margin-bottom: 24px; font-size: 28px; justify-content: center; }
        .form-group { margin-bottom: 20px; }
        .form-group label { display: block; margin-bottom: 8px; color: var(--text-secondary); font-size: 14px; font-weight: 500; }
        .form-control { width: 100%; padding: 12px; border: 1px solid var(--border); border-radius: 6px; font-size: 14px; font-family: inherit; }
        .form-control:focus { outline: none; border-color: var(--accent); }
        .btn-full { width: 100%; padding: 12px; font-size: 16px; margin-top: 10px; }
        .error-msg { color: var(--danger); font-size: 14px; margin-bottom: 16px; text-align: center; }
    </style>
</head>
<body>
    <div class="auth-container">
        <div class="brand" style="text-align: center; color: var(--text-primary);">
            Finance<span style="color: var(--accent);">Track</span>
        </div>
        <p style="text-align: center; color: var(--text-secondary); margin-bottom: 32px;">Welcome back! Please enter your details.</p>

        @if (ViewBag.Error != null)
        {
            <div class="error-msg">@ViewBag.Error</div>
        }

        <form method="post" action="/Account/Login">
            <div class="form-group">
                <label for="email">Email address</label>
                <input type="email" id="email" name="email" class="form-control" placeholder="admin@financetrack.com" required />
            </div>
            <div class="form-group">
                <label for="password">Password</label>
                <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" required />
            </div>
            <button type="submit" class="btn btn-full">Sign in</button>
        </form>
        <div style="text-align: center; margin-top: 24px; font-size: 14px; color: var(--text-secondary);">
            Don't have an account? <a href="/Account/Register" style="color: var(--accent); text-decoration: none; font-weight: 500;">Sign up</a>
        </div>
    </div>
</body>
</html>
